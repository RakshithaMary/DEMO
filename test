function showEmptyState(message = "Select a Relationship View and click Search.") {
  // Clear graph + table
  cy.elements().remove();
  populateDataTable([], []);

  // Reset side panel
  propertiesTitle.textContent = "Properties";
  propertiesPanel.innerHTML = `<p>${message}</p>`;

  // Reset header title
  queryTitle.textContent = "Knowledge Graph Explorer";
}


